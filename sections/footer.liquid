<div class="site-footer full-width">
  <div class="site-footer__inner">
    <div class="site-footer__grid">
      <div class="site-footer__col site-footer__col--brand">
        <p class="site-footer__logo">ZALVA SHAPE</p>
        <p class="site-footer__tagline">Sculpted for you.</p>
      </div>

      <nav class="site-footer__col site-footer__nav" aria-label="Footer">
        <ul class="site-footer__links" role="list">
          <li>
            <a href="{{ routes.all_products_collection_url }}">Shop</a>
          </li>
          <li>
            <a href="/pages/about">About</a>
          </li>
          <li>
            <a href="/pages/size-guide">Size Guide</a>
          </li>
          <li>
            <a href="/pages/faq">FAQ</a>
          </li>
          <li>
            <a href="/pages/contact">Contact</a>
          </li>
        </ul>
      </nav>

      <div class="site-footer__col site-footer__col--newsletter">
        {% form 'customer', class: 'site-footer__newsletter' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <label class="visually-hidden" for="SiteFooterNewsletterEmail">Email</label>
          <div class="site-footer__newsletter-row">
            <input
              id="SiteFooterNewsletterEmail"
              class="site-footer__input"
              type="email"
              name="contact[email]"
              value="{% if form.email %}{{ form.email }}{% endif %}"
              placeholder="Email address"
              autocomplete="email"
              required
            >
            <button class="site-footer__subscribe" type="submit" name="commit">
              SUBSCRIBE
            </button>
          </div>
          {% if form.posted_successfully? %}
            <p class="site-footer__form-note" role="status">Thanks for subscribing.</p>
          {% endif %}
          {% if form.errors %}
            <p class="site-footer__form-note site-footer__form-note--error">Please enter a valid email address.</p>
          {% endif %}
        {% endform %}
      </div>
    </div>

    <hr class="site-footer__rule">

    <p class="site-footer__copyright">© {{ 'now' | date: '%Y' }} Zalva Shape. All rights reserved.</p>
  </div>
</div>

{% stylesheet %}
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .site-footer {
    --zalva-ivory: #faf8f5;
    --zalva-champagne: #c8a96e;
    --zalva-noir: #1a1a1a;
    --zalva-deep-brown: #3d2b24;

    background-color: var(--zalva-ivory);
    color: var(--zalva-noir);
    padding-block: clamp(2.5rem, 6vw, 4rem);
    margin-top: auto;
  }

  .site-footer__inner {
    width: 100%;
    max-width: var(--page-width);
    margin-inline: auto;
    padding-inline: var(--page-margin);
  }

  .site-footer__grid {
    display: grid;
    gap: clamp(2rem, 5vw, 3rem);
    grid-template-columns: 1fr;
  }

  @media (min-width: 900px) {
    .site-footer__grid {
      grid-template-columns: repeat(3, 1fr);
      align-items: start;
    }
  }

  .site-footer__logo {
    font-family: 'Cormorant Garamond', 'Times New Roman', Times, serif;
    font-weight: 300;
    font-size: clamp(1.375rem, 2vw + 0.75rem, 1.75rem);
    letter-spacing: 0.14em;
    color: var(--zalva-deep-brown);
    margin: 0 0 0.5rem;
  }

  .site-footer__tagline {
    font-family: 'Cormorant Garamond', 'Times New Roman', Times, serif;
    font-weight: 300;
    font-size: 1rem;
    font-style: italic;
    color: var(--zalva-noir);
    margin: 0;
    opacity: 0.85;
  }

  .site-footer__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: flex-start;
  }

  @media (min-width: 900px) {
    .site-footer__links {
      align-items: center;
      text-align: center;
    }
  }

  .site-footer__links a {
    font-family: Jost, var(--font-primary--family), system-ui, sans-serif;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--zalva-noir);
    transition: color 0.2s ease;
  }

  .site-footer__links a:hover,
  .site-footer__links a:focus-visible {
    color: var(--zalva-deep-brown);
  }

  .site-footer__newsletter {
    width: 100%;
    max-width: 22rem;
  }

  @media (min-width: 900px) {
    .site-footer__col--newsletter {
      justify-self: end;
    }

    .site-footer__newsletter {
      margin-left: auto;
    }
  }

  .site-footer__newsletter-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: stretch;
  }

  .site-footer__input {
    font-family: Jost, var(--font-primary--family), system-ui, sans-serif;
    font-size: 0.8125rem;
    flex: 1 1 10rem;
    min-height: 2.75rem;
    padding: 0.5rem 0.75rem;
    border: 1px solid rgba(26, 26, 26, 0.2);
    border-radius: var(--style-border-radius-inputs, 2px);
    background-color: #ffffff;
    color: var(--zalva-noir);
  }

  .site-footer__input::placeholder {
    color: rgba(26, 26, 26, 0.45);
  }

  .site-footer__subscribe {
    font-family: Jost, var(--font-primary--family), system-ui, sans-serif;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.5rem 1.25rem;
    min-height: 2.75rem;
    border: none;
    cursor: pointer;
    background-color: var(--zalva-champagne);
    color: var(--zalva-noir);
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .site-footer__subscribe:hover {
    background-color: var(--zalva-deep-brown);
    color: var(--zalva-ivory);
  }

  .site-footer__subscribe:focus-visible {
    outline: 2px solid var(--zalva-deep-brown);
    outline-offset: 2px;
  }

  .site-footer__form-note {
    font-family: Jost, var(--font-primary--family), system-ui, sans-serif;
    font-size: 0.75rem;
    margin: 0.5rem 0 0;
  }

  .site-footer__form-note--error {
    color: #8b2942;
  }

  .site-footer__rule {
    border: none;
    height: 1px;
    margin: clamp(2rem, 5vw, 2.75rem) 0 clamp(1.25rem, 3vw, 1.75rem);
    background-color: rgba(26, 26, 26, 0.12);
  }

  .site-footer__copyright {
    font-family: Jost, var(--font-primary--family), system-ui, sans-serif;
    font-size: 0.75rem;
    color: rgba(26, 26, 26, 0.65);
    text-align: center;
    margin: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Footer",
  "tag": "footer",
  "class": "section-site-footer",
  "settings": []
}
{% endschema %}
