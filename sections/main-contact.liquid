<div class="main-contact full-width">
  <div class="main-contact__inner">
    <h1 class="main-contact__title">Contact Us</h1>
    <p class="main-contact__subtitle">We'd love to hear from you.</p>

    {% form 'contact', class: 'main-contact__form' %}
      {% if form.posted_successfully? %}
        <p class="main-contact__notice main-contact__notice--success" role="status">Thank you for your message. We'll be in touch soon.</p>
      {% endif %}
      {% if form.errors %}
        <p class="main-contact__notice main-contact__notice--error" role="alert">Please correct the errors below and try again.</p>
      {% endif %}

      <div class="main-contact__fields">
        <div class="main-contact__field">
          <label class="main-contact__label" for="ContactName-{{ section.id }}">Name</label>
          <input
            class="main-contact__input"
            type="text"
            id="ContactName-{{ section.id }}"
            name="contact[name]"
            value="{% if form.name %}{{ form.name }}{% endif %}"
            autocomplete="name"
            required
          >
        </div>
        <div class="main-contact__field">
          <label class="main-contact__label" for="ContactEmail-{{ section.id }}">Email</label>
          <input
            class="main-contact__input"
            type="email"
            id="ContactEmail-{{ section.id }}"
            name="contact[email]"
            value="{% if form.email %}{{ form.email }}{% endif %}"
            spellcheck="false"
            autocapitalize="off"
            autocomplete="email"
            required
          >
        </div>
        <div class="main-contact__field">
          <label class="main-contact__label" for="ContactSubject-{{ section.id }}">Subject</label>
          <input
            class="main-contact__input"
            type="text"
            id="ContactSubject-{{ section.id }}"
            name="contact[subject]"
            value=""
          >
        </div>
        <div class="main-contact__field">
          <label class="main-contact__label" for="ContactBody-{{ section.id }}">Message</label>
          <textarea
            class="main-contact__textarea"
            id="ContactBody-{{ section.id }}"
            name="contact[body]"
            rows="6"
            required
          >{{- form.body -}}</textarea>
        </div>
      </div>

      <button type="submit" class="main-contact__submit">SEND MESSAGE</button>
    {% endform %}

    <div class="main-contact__meta">
      <a class="main-contact__email" href="mailto:info@zalvashape.com">info@zalvashape.com</a>
      <p class="main-contact__note">Response within 24 hours</p>
    </div>
  </div>
</div>

{% stylesheet %}
  .main-contact {
    --zalva-ivory: #faf8f5;
    --zalva-champagne: #c8a96e;
    --zalva-noir: #1a1a1a;
    --zalva-deep-brown: #3d2b24;

    background-color: var(--zalva-ivory);
    color: var(--zalva-noir);
    padding-block: clamp(2.5rem, 6vw, 4rem);
  }

  .main-contact__inner {
    max-width: 28rem;
    margin-inline: auto;
    padding-inline: var(--page-margin);
    text-align: center;
  }

  .main-contact__title {
    font-family: 'Cormorant Garamond', 'Times New Roman', Times, serif;
    font-weight: 300;
    font-size: clamp(2.25rem, 5vw, 3rem);
    color: var(--zalva-deep-brown);
    margin: 0 0 0.5rem;
  }

  .main-contact__subtitle {
    font-family: Jost, var(--font-primary--family), system-ui, sans-serif;
    font-size: 1rem;
    font-style: italic;
    color: rgba(26, 26, 26, 0.75);
    margin: 0 0 2rem;
  }

  .main-contact__form {
    margin: 0;
    text-align: left;
  }

  .main-contact__notice {
    font-family: Jost, var(--font-primary--family), system-ui, sans-serif;
    font-size: 0.875rem;
    padding: 0.75rem 1rem;
    margin-bottom: 1.25rem;
    text-align: center;
  }

  .main-contact__notice--success {
    background-color: rgba(200, 169, 110, 0.15);
    border: 1px solid var(--zalva-champagne);
    color: var(--zalva-deep-brown);
  }

  .main-contact__notice--error {
    background-color: rgba(139, 41, 66, 0.08);
    border: 1px solid rgba(139, 41, 66, 0.35);
    color: #6b2438;
  }

  .main-contact__fields {
    display: flex;
    flex-direction: column;
    gap: 1.125rem;
  }

  .main-contact__label {
    font-family: Jost, var(--font-primary--family), system-ui, sans-serif;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 0.375rem;
    color: var(--zalva-noir);
  }

  .main-contact__input,
  .main-contact__textarea {
    font-family: Jost, var(--font-primary--family), system-ui, sans-serif;
    font-size: 0.9375rem;
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid rgba(26, 26, 26, 0.25);
    border-radius: var(--style-border-radius-inputs, 2px);
    background-color: #ffffff;
    color: var(--zalva-noir);
  }

  .main-contact__textarea {
    resize: vertical;
    min-height: 8rem;
  }

  .main-contact__input:focus-visible,
  .main-contact__textarea:focus-visible {
    outline: 2px solid var(--zalva-champagne);
    outline-offset: 1px;
    border-color: var(--zalva-champagne);
  }

  .main-contact__submit {
    font-family: Jost, var(--font-primary--family), system-ui, sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    width: 100%;
    margin-top: 1.5rem;
    padding: 1rem 1.5rem;
    min-height: 3.25rem;
    border: none;
    cursor: pointer;
    background-color: var(--zalva-champagne);
    color: var(--zalva-noir);
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .main-contact__submit:hover {
    background-color: var(--zalva-deep-brown);
    color: #ffffff;
  }

  .main-contact__meta {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(26, 26, 26, 0.1);
  }

  .main-contact__email {
    font-family: Jost, var(--font-primary--family), system-ui, sans-serif;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--zalva-champagne);
    text-decoration: none;
    border-bottom: 1px solid var(--zalva-champagne);
  }

  .main-contact__email:hover {
    color: var(--zalva-deep-brown);
    border-bottom-color: var(--zalva-deep-brown);
  }

  .main-contact__note {
    font-family: Jost, var(--font-primary--family), system-ui, sans-serif;
    font-size: 0.8125rem;
    color: rgba(26, 26, 26, 0.6);
    margin: 0.75rem 0 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Contact",
  "tag": "section",
  "class": "section-main-contact",
  "settings": [],
  "presets": [{ "name": "Contact" }]
}
{% endschema %}
