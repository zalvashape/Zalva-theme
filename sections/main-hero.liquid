{% liquid
  assign headline = section.settings.headline | default: 'Sculpted for you.'
  assign subtitle = section.settings.subtitle | default: 'Premium shapewear for every body.'
  assign button_label = section.settings.button_label | default: 'SHOP NOW'
  assign button_link = section.settings.button_link | default: routes.all_products_collection_url
  assign hero_image_alt = section.settings.hero_image_alt | default: 'Zalva Shape campaign'
  assign hero_image_url = 'https://images.unsplash.com/photo-1583846783214-7229a91b20ed?w=1200&q=80'
%}

<div class="main-hero full-width">
  <div class="main-hero__grid">
    <div class="main-hero__copy">
      <h1 class="main-hero__headline">{{ headline }}</h1>
      <p class="main-hero__subtitle">{{ subtitle }}</p>
      <a class="main-hero__cta" href="{{ button_link }}">{{ button_label }}</a>
    </div>
    <div class="main-hero__visual">
      <img
        class="main-hero__image"
        src="{{ hero_image_url }}"
        alt="{{ hero_image_alt | escape }}"
        width="1200"
        height="1500"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      >
    </div>
  </div>
</div>

{% stylesheet %}
  .main-hero {
    --zalva-ivory: #faf8f5;
    --zalva-champagne: #c8a96e;
    --zalva-warm-taupe: #a07060;
    --zalva-deep-brown: #3d2b24;
    --zalva-noir: #1a1a1a;

    min-height: 100dvh;
    min-height: 100vh;
    background-color: var(--zalva-ivory);
    color: var(--zalva-noir);
    display: flex;
    align-items: stretch;
  }

  .main-hero__grid {
    display: grid;
    width: 100%;
    max-width: var(--page-width);
    margin-inline: auto;
    padding-inline: var(--page-margin);
    grid-template-columns: 1fr;
    min-height: inherit;
    align-items: center;
    gap: clamp(2rem, 5vw, 4rem);
  }

  @media (min-width: 900px) {
    .main-hero__grid {
      grid-template-columns: 1fr 1fr;
      align-items: stretch;
      gap: clamp(2rem, 6vw, 5rem);
    }
  }

  .main-hero__copy {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    justify-content: center;
    padding-block: clamp(2.5rem, 8vh, 5rem);
  }

  @media (min-width: 900px) {
    .main-hero__copy {
      align-items: flex-start;
      text-align: left;
      padding-block: clamp(3rem, 12vh, 6rem);
    }
  }

  .main-hero__headline {
    font-family: 'Cormorant Garamond', 'Times New Roman', Times, serif;
    font-weight: 300;
    font-size: clamp(2.75rem, 6vw + 1rem, 4.5rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--zalva-deep-brown);
    max-width: 14ch;
  }

  .main-hero__subtitle {
    font-family: Jost, var(--font-primary--family), system-ui, sans-serif;
    font-weight: 400;
    font-size: clamp(1rem, 1.2vw + 0.85rem, 1.25rem);
    line-height: 1.55;
    color: var(--zalva-warm-taupe);
    margin-top: 1.25rem;
    max-width: 32ch;
  }

  .main-hero__cta {
    font-family: Jost, var(--font-primary--family), system-ui, sans-serif;
    font-weight: 500;
    font-size: 0.8125rem;
    letter-spacing: 0.14em;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 2rem;
    padding: 1rem 2.25rem;
    min-height: 3rem;
    background-color: var(--zalva-champagne);
    color: var(--zalva-noir);
    border: none;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .main-hero__cta:hover {
    background-color: var(--zalva-warm-taupe);
    color: var(--zalva-ivory);
  }

  .main-hero__cta:focus-visible {
    outline: 2px solid var(--zalva-deep-brown);
    outline-offset: 3px;
  }

  .main-hero__visual {
    position: relative;
    overflow: hidden;
    min-height: clamp(280px, 42vh, 560px);
    background-color: var(--zalva-ivory);
  }

  @media (min-width: 900px) {
    .main-hero__visual {
      min-height: 100%;
      align-self: stretch;
    }
  }

  .main-hero__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Zalva hero",
  "tag": "section",
  "class": "section-main-hero",
  "settings": [
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Sculpted for you."
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Premium shapewear for every body."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "hero_image_alt",
      "label": "Hero image alt text",
      "default": "Zalva Shape campaign"
    }
  ],
  "presets": [
    {
      "name": "Zalva hero"
    }
  ]
}
{% endschema %}
